<Window
    x:Class="WinSizeUI3.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="WinSize">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="44"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Top bar: title left, feedback button anchored top-right -->
        <Border Grid.Row="0"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                BorderThickness="0,0,0,1">
            <Grid>
                <TextBlock Text="WinSize" VerticalAlignment="Center" Margin="16,0,0,0"
                           Style="{ThemeResource BodyStrongTextBlockStyle}"/>
                <HyperlinkButton Content="Feedback"
                                 NavigateUri="https://github.com/dataappsolutions/WinSize/issues"
                                 HorizontalAlignment="Right" VerticalAlignment="Center"
                                 Margin="0,0,8,0"/>
            </Grid>
        </Border>

        <!-- Main content -->
        <Grid Grid.Row="1" Margin="16,12,16,16" ColumnSpacing="12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <!-- label row -->
                <RowDefinition Height="*"/>
                <!-- list + controls row -->
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="280"/>
            </Grid.ColumnDefinitions>

            <!-- Label above list only -->
            <TextBlock Grid.Row="0" Grid.Column="0"
               Text="Open Windows"
               Style="{ThemeResource CaptionTextBlockStyle}"
               Margin="0,0,0,4"/>

            <!-- ListView starts at Row 1 -->
            <ListView Grid.Row="1" Grid.Column="0" x:Name="WindowsListView" SelectionMode="Single"
              BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
              BorderThickness="1" CornerRadius="4">
                <ListView.ItemContainerStyle>
                    <Style TargetType="ListViewItem" BasedOn="{StaticResource DefaultListViewItemStyle}">
                        <Setter Property="MinHeight" Value="28"/>
                        <Setter Property="Padding" Value="12,10"/>
                    </Style>
                </ListView.ItemContainerStyle>
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding}" TextWrapping="NoWrap"/>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

            <!-- Right controls also start at Row 1 — top-aligned with ListView -->
            <StackPanel Grid.Row="1" Grid.Column="1" Spacing="12" VerticalAlignment="Top">
                <ComboBox x:Name="PresetsComboBox"
                  PlaceholderText="Select a preset..."
                  HorizontalAlignment="Stretch"
                  SelectionChanged="PresetsComboBox_SelectionChanged">
                    <ComboBox.ItemContainerStyle>
                        <Style TargetType="ComboBoxItem">
                            <Setter Property="MinHeight" Value="28"/>
                            <Setter Property="Padding" Value="12,4"/>
                        </Style>
                    </ComboBox.ItemContainerStyle>
                </ComboBox>

                <StackPanel Spacing="4">
                    <TextBlock Text="Width" Style="{ThemeResource CaptionTextBlockStyle}"/>
                    <NumberBox x:Name="WidthBox" Minimum="1" Maximum="10000" Value="800"
                       SpinButtonPlacementMode="Inline"/>
                </StackPanel>

                <StackPanel Spacing="4">
                    <TextBlock Text="Height" Style="{ThemeResource CaptionTextBlockStyle}"/>
                    <NumberBox x:Name="HeightBox" Minimum="1" Maximum="10000" Value="600"
                       SpinButtonPlacementMode="Inline"/>
                </StackPanel>

                <CheckBox x:Name="CenterCheckBox" Content="Center Align Before Resizing?"/>

                <Button Content="Refresh" HorizontalAlignment="Stretch"
                Click="RefreshButton_Click"/>
                <Button Content="Resize Window" HorizontalAlignment="Stretch"
                Click="ResizeButton_Click" Style="{ThemeResource AccentButtonStyle}"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>    
    
    
